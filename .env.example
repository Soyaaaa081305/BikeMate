ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Server=localhost;Database=BikeMatesDB;Trusted_Connection=True;TrustServerCertificate=True;
Jwt__Issuer=BikeMate
Jwt__Audience=BikeMateMobile
Jwt__Key=CHANGE_THIS_TO_A_LONG_SECURE_SECRET_AT_LEAST_32_CHARS
GoogleMaps__ApiKey=YOUR_GOOGLE_MAPS_API_KEY
GoogleAuth__ClientId=YOUR_GOOGLE_WEB_CLIENT_ID
GoogleAuth__AndroidClientId=YOUR_GOOGLE_ANDROID_CLIENT_ID
GoogleAuth__WebClientId=YOUR_GOOGLE_WEB_CLIENT_ID
SendGrid__ApiKey=YOUR_SENDGRID_API_KEY
SendGrid__FromEmail=no-reply@bikemate.local
SendGrid__FromName=BikeMate
PayMongo__PublicKey=pk_test_xxxxx
PayMongo__SecretKey=sk_test_xxxxx
PayMongo__WebhookSecret=whsec_xxxxx
PayMongo__SuccessUrl=bikemate://payment-success
PayMongo__CancelUrl=bikemate://payment-cancelled
Firebase__ProjectId=YOUR_FIREBASE_PROJECT_ID
Firebase__ServiceAccountPath=firebase-service-account.json
Agora__AppId=YOUR_AGORA_APP_ID
Agora__PrimaryCertificate=YOUR_AGORA_PRIMARY_CERTIFICATE
Storage__Provider=AzureBlob
Storage__ConnectionString=YOUR_AZURE_BLOB_CONNECTION_STRING
Storage__ContainerName=bikemate-files
