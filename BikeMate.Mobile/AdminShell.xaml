<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="BikeMate.AdminShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:admin="clr-namespace:BikeMate.Views.Admin"
    Title="Admin"
    Shell.NavBarIsVisible="False">

    <TabBar>
        <ShellContent Title="Dashboard" ContentTemplate="{DataTemplate admin:AdminDashboardPage}" />
        <ShellContent Title="Users" ContentTemplate="{DataTemplate admin:AdminUsersPage}" />
        <ShellContent Title="Requests" ContentTemplate="{DataTemplate admin:AdminRequestsPage}" />
        <ShellContent Title="Payments" ContentTemplate="{DataTemplate admin:AdminPaymentsPage}" />
        <ShellContent Title="Reports" ContentTemplate="{DataTemplate admin:AdminReportsPage}" />
    </TabBar>
</Shell>
