<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="BikeMate.ShopAdminShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shop="clr-namespace:BikeMate.Views.ShopAdmin"
    Title="Shop Admin"
    Shell.NavBarIsVisible="False">

    <TabBar>
        <ShellContent Title="Dashboard" ContentTemplate="{DataTemplate shop:ShopDashboardPage}" />
        <ShellContent Title="Profile" ContentTemplate="{DataTemplate shop:ShopProfilePage}" />
        <ShellContent Title="Services" ContentTemplate="{DataTemplate shop:ShopServicesPage}" />
        <ShellContent Title="Products" ContentTemplate="{DataTemplate shop:ShopProductsPage}" />
        <ShellContent Title="Bookings" ContentTemplate="{DataTemplate shop:ShopBookingsPage}" />
    </TabBar>
</Shell>
