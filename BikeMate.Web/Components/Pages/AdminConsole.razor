@page "/"
@page "/admin"
@inject ApiClient Api
@inject BrowserStorage Storage
@inject NavigationManager Navigation

<PageTitle>BikeMate Admin</PageTitle>

<div class="admin-shell">
    <aside class="sidebar">
        <div class="brand">
            <div class="brand-mark">B</div>
            <div>
                <div class="brand-name">BIKEMATE</div>
                <div class="brand-subtitle">Operations Console</div>
            </div>
        </div>

        <div class="nav-section">Overview</div>
        <button class="nav-item active" @onclick="() => ScrollToTop()">Dashboard</button>

        <div class="nav-section">Operations</div>
        <button class="nav-item" @onclick="() => ScrollToSection()">Emergency</button>
        <button class="nav-item" @onclick="() => ScrollToSection()">Users</button>
        <button class="nav-item" @onclick="() => ScrollToSection()">Shops</button>
        <button class="nav-item" @onclick="() => ScrollToSection()">Mechanics</button>
        <button class="nav-item" @onclick="() => ScrollToSection()">Requests</button>
        <button class="nav-item" @onclick="() => ScrollToSection()">Payments</button>

        <div class="sidebar-spacer"></div>

        @if (IsAuthenticated)
        {
            <button class="nav-item logout" @onclick="LogoutAsync">Logout</button>
        }
    </aside>

    <main class="content">
        @if (!IsAuthenticated)
        {
            <section class="login-panel">
                <div class="login-copy">
                    <div class="eyebrow">BikeMate Admin</div>
                    <h1>Operations Console</h1>
                    <p>Sign in with an admin account to connect this Blazor web app to the BikeMate API.</p>
                </div>

                <div class="login-card">
                    <div class="field">
                        <label>Email address</label>
                        <input @bind="Email" />
                    </div>
                    <div class="field">
                        <label>Password</label>
                        <input type="password" @bind="Password" />
                    </div>
                    <button class="primary" @onclick="LoginAsync" disabled="@IsBusy">Sign in</button>
                    <div class="status">@Status</div>
                </div>
            </section>
        }
        else
        {
            <section class="topbar">
                <div>
                    <div class="eyebrow">BikeMate Admin</div>
                    <h1>Operations Console</h1>
                </div>
                <div class="topbar-actions">
                    <span class="user-pill">@CurrentUserEmail</span>
                    <button class="ghost" @onclick="LoadAsync" disabled="@IsBusy">Refresh Data</button>
                    <button class="danger" @onclick="LogoutAsync">Logout</button>
                </div>
            </section>

            <section class="overview-heading">
                <div>
                    <h2>System Overview</h2>
                    <p>Live data pulled from the BikeMate API.</p>
                </div>
                <button class="ghost accent" @onclick="LoadAsync" disabled="@IsBusy">Refresh Data</button>
            </section>

            <section class="alert-card">
                <div>
                    <div class="alert-title">Emergency Window</div>
                    <div class="alert-text">@EmergencySummary</div>
                </div>
                <button class="danger" @onclick="GoEmergency">Open Emergency Window</button>
            </section>

            <section class="metrics-grid">
                <article class="panel wide">
                    <div class="panel-header">
                        <h3>Weekly User Growth</h3>
                        <button class="ghost small" @onclick="LoadAsync">View Directory</button>
                    </div>
                    <div class="metric-value">@Dashboard.TotalCustomers</div>
                    <div class="metric-label">Total Customers</div>
                    <div class="bars">
                        @foreach (var point in WeeklyGrowth)
                        {
                            <div class="bar-column">
                                <div class="bar-track">
                                    <div class="bar-fill" style="height:@($"{Math.Max(point.Height, 8)}px")"></div>
                                </div>
                                <div class="bar-label">@point.Day</div>
                            </div>
                        }
                    </div>
                </article>

                <article class="panel">
                    <h3>Network Health</h3>

                    <div class="health-row">
                        <div>
                            <div class="health-title">Mechanics Online</div>
                            <div class="health-value">@OnlineMechanics / @VerifiedMechanics Active</div>
                        </div>
                        <button class="link" @onclick="LoadAsync">Manage</button>
                    </div>
                    <div class="progress"><div class="progress-fill green" style="width:@($"{MechanicOnlinePercent}%")"></div></div>

                    <hr />

                    <div class="health-row">
                        <div>
                            <div class="health-title">Verified Partner Shops</div>
                            <div class="health-value">@VerifiedShops / @Shops.Count Total</div>
                        </div>
                        <button class="link" @onclick="LoadAsync">Manage</button>
                    </div>
                    <div class="progress"><div class="progress-fill blue" style="width:@($"{ShopVerifiedPercent}%")"></div></div>
                </article>
            </section>

            <section class="panel requests">
                <div class="panel-header">
                    <h3>Live Service Requests (@LiveRequests.Count Active)</h3>
                    <button class="ghost small" @onclick="LoadAsync">View Tracker Board</button>
                </div>

                @if (LiveRequests.Count == 0)
                {
                    <div class="empty-state">No live requests are active right now.</div>
                }
                else
                {
                    @foreach (var request in LiveRequests)
                    {
                        <div class="request-row">
                            <div>
                                <div class="request-title">#@request.RequestId @Trim(request.IssueDescription, 52)</div>
                                <div class="request-subtitle">@request.CustomerName @Separator(request.ShopName) @request.ShopName @Separator(request.ServiceName) @request.ServiceName</div>
                                <div class="request-location">@request.ServiceLocationAddress</div>
                            </div>
                            <div class="request-meta">
                                <span class="status-pill" style="background:@StatusColor(request.CurrentStatus)">@request.CurrentStatus</span>
                                <div>PHP @request.FinalTotal.ToString("0.00")</div>
                                <div>@request.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</div>
                            </div>
                        </div>
                    }
                }
            </section>
        }
    </main>
</div>

@code {
    private const string AdminRole = "SystemAdmin";
    private string? Email { get; set; } = "admin@bikemate.test";
    private string? Password { get; set; } = "Password123!";
    private string Status { get; set; } = "Use an admin account to sign in.";
    private string? Token { get; set; }
    private bool IsBusy { get; set; }
    private bool IsAuthenticated => !string.IsNullOrWhiteSpace(Token);
    private string CurrentUserEmail => Profile?.Email ?? Email ?? "admin@bikemate.test";
    private UserProfileDto? Profile { get; set; }
    private AdminDashboardDto Dashboard { get; set; } = new(0, 0, 0, 0, 0, 0, 0m, 0);
    private List<CustomerRow> Customers { get; set; } = [];
    private List<MechanicRow> Mechanics { get; set; } = [];
    private List<ShopRow> Shops { get; set; } = [];
    private List<ServiceRequestDto> Requests { get; set; } = [];

    private IReadOnlyList<ServiceRequestDto> LiveRequests =>
        Requests.Where(x => !IsTerminalStatus(x.CurrentStatus)).Take(6).ToArray();

    private int VerifiedMechanics => Mechanics.Count(x => x.IsVerified);
    private int OnlineMechanics => Mechanics.Count(x => x.IsVerified && IsOnlineStatus(x.AvailabilityStatus));
    private int VerifiedShops => Shops.Count(x => string.Equals(x.ShopStatus, "verified", StringComparison.OrdinalIgnoreCase));
    private int MechanicOnlinePercent => VerifiedMechanics == 0 ? 0 : (int)Math.Round((double)OnlineMechanics / VerifiedMechanics * 100);
    private int ShopVerifiedPercent => Shops.Count == 0 ? 0 : (int)Math.Round((double)VerifiedShops / Shops.Count * 100);
    private string EmergencySummary => LiveRequests.Count > 0
        ? $"{LiveRequests.Count} active emergency request{(LiveRequests.Count == 1 ? string.Empty : "s")} need monitoring."
        : "All monitored services are currently in a steady state.";
    private List<GrowthPoint> WeeklyGrowth { get; set; } = [new("Mon", 8), new("Tue", 8), new("Wed", 8), new("Thu", 8), new("Fri", 8), new("Sat", 8), new("Sun", 8)];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Token = await Storage.GetItemAsync("bikemate_token");
        if (string.IsNullOrWhiteSpace(Token))
        {
            return;
        }

        Profile = await Storage.GetItemAsync<UserProfileDto>("bikemate_profile");
        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
        {
            Status = "Enter email and password.";
            return;
        }

        IsBusy = true;
        Status = "Signing in...";
        try
        {
            var auth = await Api.LoginAsync(new LoginRequestDto(Email.Trim(), Password));
            if (!auth.User.Roles.Any(r => string.Equals(r, AdminRole, StringComparison.OrdinalIgnoreCase)))
            {
                Status = "This account does not have the SystemAdmin role.";
                return;
            }

            Token = auth.AccessToken;
            Profile = auth.User;
            await Storage.SetItemAsync("bikemate_token", Token);
            await Storage.SetItemAsync("bikemate_profile", Profile);
            Status = "Signed in.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Status = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            return;
        }

        IsBusy = true;
        Status = "Loading live data...";
        try
        {
            var dashboardTask = Api.GetAdminDashboardAsync(Token);
            var customersTask = Api.GetAdminCustomersAsync(Token);
            var mechanicsTask = Api.GetAdminMechanicsAsync(Token);
            var shopsTask = Api.GetAdminShopsAsync(Token);
            var requestsTask = Api.GetAdminServiceRequestsAsync(Token);
            var meTask = Api.GetMeAsync(Token);

            await Task.WhenAll(dashboardTask, customersTask, mechanicsTask, shopsTask, requestsTask, meTask);

            Dashboard = await dashboardTask;
            Customers = (await customersTask).ToList();
            Mechanics = (await mechanicsTask).ToList();
            Shops = (await shopsTask).ToList();
            Requests = (await requestsTask).ToList();
            Profile = await meTask;
            WeeklyGrowth = BuildWeeklyGrowth(Customers);

            Status = "Live data loaded.";
        }
        catch (Exception ex)
        {
            Status = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task LogoutAsync()
    {
        await Storage.RemoveAsync("bikemate_token");
        await Storage.RemoveAsync("bikemate_profile");
        Token = null;
        Profile = null;
        Requests.Clear();
        Customers.Clear();
        Mechanics.Clear();
        Shops.Clear();
        Status = "Logged out.";
    }

    private void GoEmergency()
    {
        Navigation.NavigateTo("/admin");
    }

    private static bool IsOnlineStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return false;
        }

        var normalized = status.Trim().ToLowerInvariant();
        return normalized is "available" or "active" or "online" or "working";
    }

    private static bool IsTerminalStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return false;
        }

        var normalized = status.Trim().ToLowerInvariant();
        return normalized is "completed" or "cancelled" or "rejected" or "refunded";
    }

    private static string StatusColor(string? status)
    {
        var normalized = status?.Trim().ToLowerInvariant();
        return normalized switch
        {
            "completed" => "#1C8C5A",
            "in_progress" => "#1EA7D8",
            "accepted" => "#E09A1F",
            "arrived" => "#8E63D9",
            "cancelled" => "#D63C4E",
            "pending" => "#FF6B2C",
            _ => "#64748B"
        };
    }

    private static string Trim(string? text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return "Request";
        }

        return text.Length <= maxLength ? text : text[..maxLength] + "...";
    }

    private static string Separator(string? value) => string.IsNullOrWhiteSpace(value) ? string.Empty : " | ";

    private static List<GrowthPoint> BuildWeeklyGrowth(IReadOnlyCollection<CustomerRow> customers)
    {
        var start = DateTime.UtcNow.Date.AddDays(-6);
        var counts = new int[7];

        foreach (var customer in customers)
        {
            var created = customer.CreatedAt.ToUniversalTime().Date;
            if (created < start || created > DateTime.UtcNow.Date)
            {
                continue;
            }

            var index = (created - start).Days;
            if (index >= 0 && index < counts.Length)
            {
                counts[index]++;
            }
        }

        var max = Math.Max(1, counts.Max());
        var result = new List<GrowthPoint>(7);
        for (var i = 0; i < 7; i++)
        {
            result.Add(new GrowthPoint(start.AddDays(i).ToString("ddd"), 8 + (int)Math.Round((counts[i] / (double)max) * 64)));
        }

        return result;
    }

    private void ScrollToTop()
    {
    }

    private void ScrollToSection()
    {
    }

    private sealed record GrowthPoint(string Day, int Height);
}
