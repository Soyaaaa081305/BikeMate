{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=BikeMatesDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "BikeMate",
    "Audience": "BikeMateMobile",
    "Key": "CHANGE_THIS_FOR_LOCAL_DEVELOPMENT_ONLY_32_CHARS_MIN"
  },
  "GoogleMaps": {
    "ApiKey": "YOUR_DEV_GOOGLE_MAPS_API_KEY"
  },
  "GoogleAuth": {
    "ClientId": "YOUR_DEV_GOOGLE_CLIENT_ID"
  },
  "SendGrid": {
    "ApiKey": "YOUR_DEV_SENDGRID_API_KEY",
    "FromEmail": "no-reply@bikemate.local",
    "FromName": "BikeMate"
  },
  "PayMongo": {
    "PublicKey": "pk_test_xxxxx",
    "SecretKey": "sk_test_xxxxx",
    "WebhookSecret": "whsec_xxxxx",
    "SuccessUrl": "bikemate://payment-success",
    "CancelUrl": "bikemate://payment-cancelled"
  },
  "Firebase": {
    "ProjectId": "YOUR_DEV_FIREBASE_PROJECT_ID",
    "ServiceAccountPath": "firebase-service-account.json"
  },
  "Storage": {
    "Provider": "LocalPlaceholder",
    "BaseUrl": "https://localhost:5001/uploads"
  }
}
