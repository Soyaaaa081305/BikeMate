@page "/requests/details/{Id:int}"
@rendermode InteractiveServer
@using BikeMate.WebAdmin.DTOs
@using BikeMate.WebAdmin.Services
@inject AdminApiClient AdminApi

<PageTitle>Service Request #@Id</PageTitle>

<div class="mb-4 mt-3 d-flex justify-content-between align-items-start">
    <div>
        <a href="/requests" class="btn btn-sm btn-outline-secondary mb-3 shadow-sm">
            <i class="bi bi-arrow-left"></i> Back to Active Services
        </a>
        <h2 class="fw-bold text-dark mb-0">Service Tracker</h2>
    </div>
</div>

<ActionMessage Message="@statusMessage" AlertType="@statusAlertType" OnMessageCleared="() => statusMessage = null" />

@if (request == null)
{
    <div class="p-5 text-center">
        <div class="spinner-border text-warning" role="status"></div>
        <p class="mt-2 text-muted">Loading service details...</p>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 h-100 border-top border-warning border-4">
                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="fw-bold text-dark mb-0">@request.ServiceName</h3>

                        @if (request.Status.ToLower() == "completed")
                        {
                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">COMPLETED</span>
                        }
                        else if (request.Status.ToLower() == "in progress")
                        {
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2">IN PROGRESS</span>
                        }
                        else
                        {
                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 text-dark rounded-pill px-3 py-2">@request.Status.ToUpper()</span>
                        }
                    </div>

                    <h6 class="fw-bold text-uppercase text-muted mb-2">Problem Description</h6>
                    <p class="mb-4 bg-light p-3 rounded">@request.Description</p>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="fw-bold text-uppercase text-muted border-bottom pb-2 mb-3"><i class="bi bi-person me-2"></i>Customer Details</h6>
                            <p class="mb-1 fw-bold">@request.CustomerName</p>
                            <p class="mb-2 small text-muted"><i class="bi bi-telephone me-2"></i>@request.CustomerPhone</p>

                            @if (request.Latitude.HasValue && request.Longitude.HasValue)
                            {
                                <div class="mt-3 p-3 bg-light rounded border">
                                    <p class="small text-muted mb-2 fw-bold text-uppercase"><i class="bi bi-geo-alt-fill text-danger me-1"></i> GPS Coordinates Logged</p>
                                    <a href="https://www.google.com/maps/search/?api=1&query=@request.Latitude,@request.Longitude"
                                       target="_blank"
                                       class="btn btn-sm btn-primary shadow-sm w-100">
                                        <i class="bi bi-map me-1"></i> Open in Google Maps
                                    </a>
                                </div>
                            }
                            else
                            {
                                <p class="mb-1 small text-muted"><i class="bi bi-geo-alt me-2"></i>No location data provided</p>
                            }

                            <a href="/users/edit/@request.CustomerId" class="btn btn-sm btn-link px-0 mt-3">View User Profile</a>
                        </div>

                        <div class="col-md-6">
                            <h6 class="fw-bold text-uppercase text-muted border-bottom pb-2 mb-3"><i class="bi bi-tools me-2"></i>Assigned Mechanic</h6>
                            <p class="mb-1 fw-bold text-primary">@request.MechanicName</p>
                            <p class="mb-1 small text-muted"><i class="bi bi-telephone me-2"></i>@request.MechanicPhone</p>
                            <p class="mb-1 small text-muted"><i class="bi bi-shop me-2"></i>@request.ShopName</p>

                            @if (request.MechanicId.HasValue)
                            {
                                <a href="/mechanics/details/@request.MechanicId" class="btn btn-sm btn-link px-0 mt-2">View Mechanic Profile</a>
                            }
                        </div>
                    </div>

                    <div class="mt-4 pt-4 border-top">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h5 class="fw-bold mb-0 text-dark">Emergency Assignment</h5>
                                <p class="text-muted small mb-0">Mechanics are sorted by availability, distance, and rating.</p>
                            </div>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAssignmentData" disabled="@isAssignmentLoading">
                                <i class="bi bi-arrow-clockwise me-1"></i> Refresh
                            </button>
                        </div>

                        @if (isAssignmentLoading)
                        {
                            <div class="p-3 text-center border rounded bg-light">
                                <div class="spinner-border spinner-border-sm text-warning" role="status"></div>
                                <span class="ms-2 text-muted">Loading nearby mechanics...</span>
                            </div>
                        }
                        else if (mechanicCandidates.Length == 0)
                        {
                            <div class="p-3 border rounded bg-light text-muted">No active mechanic candidates found.</div>
                        }
                        else
                        {
                            <div class="row g-3">
                                <div class="col-md-7">
                                    <label class="form-label fw-semibold">Available mechanic</label>
                                    <select class="form-select" @bind="selectedMechanicId" disabled="@isAssigning">
                                        <option value="">Select mechanic...</option>
                                        @foreach (var mechanic in mechanicCandidates)
                                        {
                                            <option value="@mechanic.Id">
                                                @mechanic.Name - @mechanic.Status - @FormatDistance(mechanic.DistanceKm)
                                            </option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label fw-semibold">Admin note</label>
                                    <input class="form-control" placeholder="Optional instructions" @bind="assignmentNote" disabled="@isAssigning" />
                                </div>
                            </div>

                            <div class="table-responsive mt-3 border rounded">
                                <table class="table table-sm table-hover align-middle mb-0">
                                    <thead class="table-light text-muted small text-uppercase">
                                        <tr>
                                            <th class="ps-3">Mechanic</th>
                                            <th>Status</th>
                                            <th>Distance</th>
                                            <th>Load</th>
                                            <th class="text-end pe-3">Rating</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var mechanic in mechanicCandidates.Take(5))
                                        {
                                            <tr class="@(selectedMechanicId == mechanic.Id ? "table-warning" : "")">
                                                <td class="ps-3">
                                                    <button type="button" class="btn btn-link p-0 fw-semibold text-decoration-none" @onclick="() => SelectMechanic(mechanic.Id)">
                                                        @mechanic.Name
                                                    </button>
                                                    <div class="small text-muted">@mechanic.Phone • @mechanic.CurrentShopName</div>
                                                </td>
                                                <td>
                                                    @if (mechanic.IsAvailableNow)
                                                    {
                                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">Available now</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25">@mechanic.Status</span>
                                                    }
                                                </td>
                                                <td>@FormatDistance(mechanic.DistanceKm)</td>
                                                <td>@mechanic.ActiveRequestCount active</td>
                                                <td class="text-end pe-3">@((mechanic.Rating ?? 0).ToString("N1"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <button class="btn btn-danger shadow-sm mt-3" @onclick="AssignSelectedMechanic" disabled="@(selectedMechanicId == null || isAssigning)">
                                @if (isAssigning)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                <i class="bi bi-person-check me-1"></i> Assign Mechanic
                            </button>
                        }
                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 bg-light">
                <div class="card-body pt-4">
                    <h5 class="fw-bold text-dark mb-4">Service Record</h5>

                    <ul class="list-group list-group-flush shadow-sm rounded mb-4">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Request ID
                            <span class="badge bg-secondary rounded-pill">#@request.RequestId</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Date Created
                            <span class="text-muted small">@request.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </li>
                    </ul>

                    <h6 class="fw-bold text-uppercase text-muted mb-3 mt-4">Financials</h6>
                    <div class="bg-white p-3 rounded shadow-sm border">
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                            <span class="text-muted">Total Cost</span>
                            <span class="fw-bold fs-5 text-success">?@request.TotalAmount.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Payment Status</span>
                            @if (request.PaymentStatus.ToLower() == "paid")
                            {
                                <span class="badge bg-success">Paid</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@request.PaymentStatus</span>
                            }
                        </div>
                    </div>

                    <h6 class="fw-bold text-uppercase text-muted mb-3 mt-4">Customer Communication</h6>
                    <div class="bg-white rounded shadow-sm border">
                        <div class="request-chat p-3">
                            @if (messages.Length == 0)
                            {
                                <div class="text-muted small text-center py-3">No messages yet.</div>
                            }
                            else
                            {
                                @foreach (var message in messages)
                                {
                                    <div class="mb-3 @(message.IsAdminSender ? "text-end" : "")">
                                        <div class="small text-muted">@message.SenderName • @message.CreatedAt.ToString("MMM dd, h:mm tt")</div>
                                        <div class="d-inline-block px-3 py-2 rounded @(message.IsAdminSender ? "bg-warning bg-opacity-25" : "bg-light border")">
                                            @message.MessageText
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                        <div class="border-top p-3">
                            <textarea class="form-control mb-2" rows="3" placeholder="Message the customer and assigned mechanic..." @bind="newMessage" disabled="@isSendingMessage"></textarea>
                            <button class="btn btn-sm btn-primary w-100" @onclick="SendMessage" disabled="@(isSendingMessage || string.IsNullOrWhiteSpace(newMessage))">
                                @if (isSendingMessage)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                <i class="bi bi-send me-1"></i> Send Message
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private ServiceRequestDetailsDto? request;
    private ServiceRequestMechanicCandidateDto[] mechanicCandidates = Array.Empty<ServiceRequestMechanicCandidateDto>();
    private RequestMessageDto[] messages = Array.Empty<RequestMessageDto>();
    private int? selectedMechanicId;
    private string? assignmentNote;
    private string? newMessage;
    private string? statusMessage;
    private string statusAlertType = "danger";
    private bool isAssignmentLoading;
    private bool isAssigning;
    private bool isSendingMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadRequest();
        await LoadAssignmentData();
        await LoadMessages();
    }

    private async Task LoadRequest()
    {
        request = await AdminApi.GetServiceRequestDetailsAsync(Id);
    }

    private async Task LoadAssignmentData()
    {
        isAssignmentLoading = true;

        try
        {
            mechanicCandidates = await AdminApi.GetMechanicCandidatesForRequestAsync(Id);
            selectedMechanicId ??= mechanicCandidates.FirstOrDefault(m => m.IsAvailableNow)?.Id;
        }
        finally
        {
            isAssignmentLoading = false;
        }
    }

    private async Task LoadMessages()
    {
        messages = await AdminApi.GetRequestMessagesAsync(Id);
    }

    private void SelectMechanic(int mechanicId)
    {
        selectedMechanicId = mechanicId;
    }

    private async Task AssignSelectedMechanic()
    {
        if (selectedMechanicId == null)
        {
            return;
        }

        isAssigning = true;
        statusMessage = null;

        try
        {
            await AdminApi.AssignEmergencyMechanicAsync(Id, selectedMechanicId.Value, assignmentNote);
            statusAlertType = "success";
            statusMessage = "Mechanic assigned and conversation notified.";
            assignmentNote = null;
            await LoadRequest();
            await LoadAssignmentData();
            await LoadMessages();
        }
        catch (Exception ex)
        {
            statusAlertType = "danger";
            statusMessage = ex.Message;
        }
        finally
        {
            isAssigning = false;
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(newMessage))
        {
            return;
        }

        isSendingMessage = true;
        statusMessage = null;

        try
        {
            await AdminApi.SendAdminMessageAsync(Id, newMessage);
            newMessage = null;
            await LoadMessages();
        }
        catch (Exception ex)
        {
            statusAlertType = "danger";
            statusMessage = ex.Message;
        }
        finally
        {
            isSendingMessage = false;
        }
    }

    private static string FormatDistance(double? distanceKm)
    {
        return distanceKm.HasValue ? $"{distanceKm.Value:N1} km" : "No GPS";
    }
}
