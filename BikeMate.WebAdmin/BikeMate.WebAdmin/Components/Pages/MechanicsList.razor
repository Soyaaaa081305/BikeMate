@page "/mechanics"
@rendermode InteractiveServer
@using BikeMate.WebAdmin.DTOs
@using BikeMate.WebAdmin.Services
@inject AdminApiClient AdminApi

<PageTitle>Admin - Mechanic Directory</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold text-dark">Mechanic Directory</h2>
    <div class="d-flex gap-3 align-items-center" style="max-width: 400px; width: 100%;">
        <div class="input-group shadow-sm">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control border-start-0" placeholder="Search mechanics..."
                   @bind="searchTerm" @bind:event="oninput" />
        </div>
        <a href="/dashboard" class="btn btn-outline-secondary shadow-sm text-nowrap">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (mechanics == null)
        {
            <div class="p-5 text-center">
                <div class="spinner-border text-success" role="status"></div>
                <p class="mt-2 text-muted">Loading mechanics...</p>
            </div>
        }
        else if (mechanics.Length == 0)
        {
            <div class="p-5 text-center text-muted">
                No mechanics found in the system.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Name</th>
                            <th>Rating</th>
                            <th>Total Jobs</th>
                            <th>Current Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mechanic in FilteredMechanics)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@mechanic.Id</td>
                                <td class="fw-semibold">@mechanic.Name</td>
                                <td>? @mechanic.Rating</td>
                                <td>@mechanic.TotalJobs</td>
                                <td>
                                    @if (mechanic.Status.ToLower() == "online")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill">Online</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill">Offline</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/mechanics/details/@mechanic.Id" class="btn btn-sm btn-outline-primary shadow-sm">View Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private BikeMate.WebAdmin.DTOs.MechanicDto[]? mechanics;
    private string searchTerm = "";

    private IEnumerable<MechanicDto> FilteredMechanics => string.IsNullOrWhiteSpace(searchTerm)
        ? mechanics ?? Array.Empty<MechanicDto>()
        : mechanics!.Where(m => m.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
    protected override async Task OnInitializedAsync()
    {
        var fetchedMechanics = await AdminApi.GetMechanicsAsync();
        if (fetchedMechanics != null)
        {
            // Sort so "online" is at the top
            mechanics = fetchedMechanics
                .OrderByDescending(m => m.Status.ToLower() == "online")
                .ToArray();
        }
    }
}