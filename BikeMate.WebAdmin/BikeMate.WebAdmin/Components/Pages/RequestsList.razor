@page "/requests"
@rendermode InteractiveServer
@using BikeMate.WebAdmin.DTOs
@using BikeMate.WebAdmin.Services
@inject AdminApiClient AdminApi

<PageTitle>Active Services</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold text-dark">Active Services</h2>

    <div class="d-flex gap-3 align-items-center" style="max-width: 400px; width: 100%;">
        <div class="input-group shadow-sm">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control border-start-0" placeholder="Search by customer or ID..."
                   @bind="searchTerm" @bind:event="oninput" />
        </div>
        <a href="/dashboard" class="btn btn-outline-secondary shadow-sm text-nowrap">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (requests == null)
        {
            <div class="p-5 text-center">
                <div class="spinner-border text-warning" role="status"></div>
                <p class="mt-2 text-muted">Loading active services...</p>
            </div>
        }
        else if (requests.Length == 0)
        {
            <div class="p-5 text-center text-muted">No active service requests at this time.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">Req ID</th>
                            <th>Customer</th>
                            <th>Service Type</th>
                            <th>Status</th>
                            <th>Amount</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in FilteredRequests)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@req.Id</td>
                                <td class="fw-semibold">@req.ClientName</td>
                                <td>@req.ServiceName</td>
                                <td>
                                    @if (req.Status.ToLower() == "in progress")
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-3 py-1 text-dark">IN PROGRESS</span>
                                    }
                                    else if (req.Status.ToLower() == "pending")
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3 py-1 text-dark">PENDING</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border rounded-pill px-3 py-1">@req.Status.ToUpper()</span>
                                    }
                                </td>
                                <td class="text-success fw-bold">&#8369;@req.TotalAmount.ToString("N2")</td>
                                <td class="text-end pe-4">
                                    <a href="/requests/details/@req.Id" class="btn btn-sm btn-outline-primary shadow-sm">View Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private ServiceRequestDto[]? requests;
    private string searchTerm = "";

    // Live Search Logic
    private IEnumerable<ServiceRequestDto> FilteredRequests => string.IsNullOrWhiteSpace(searchTerm)
        ? requests ?? Array.Empty<ServiceRequestDto>()
        : requests!.Where(r => r.ClientName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                               r.ServiceName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                               r.Id.ToString() == searchTerm);

    protected override async Task OnInitializedAsync()
    {
        requests = await AdminApi.GetActiveRequestsAsync();
    }
}
