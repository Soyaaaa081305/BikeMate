@page "/shops"
@rendermode InteractiveServer
@using BikeMate.WebAdmin.DTOs
@using BikeMate.WebAdmin.Services
@inject AdminApiClient AdminApi

<PageTitle>Admin - Shop Directory</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold text-dark">Shop Directory</h2>

    <div class="d-flex gap-3 align-items-center" style="max-width: 400px; width: 100%;">
        <div class="input-group shadow-sm">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control border-start-0" placeholder="Search..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <a href="/dashboard" class="btn btn-outline-secondary shadow-sm text-nowrap">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<ActionMessage Message="@statusMessage" AlertType="danger" OnMessageCleared="() => statusMessage = null" />

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (shops == null)
        {
            <div class="p-5 text-center">
                <div class="spinner-border text-info" role="status"></div>
                <p class="mt-2 text-muted">Loading shop directory...</p>
            </div>
        }
        else if (shops.Length == 0)
        {
            <div class="p-5 text-center text-muted">
                No shops registered in the system yet.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">Shop ID</th>
                            <th>Shop Name</th>
                            <th>City</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var shop in FilteredShops)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@shop.Id</td>
                                <td class="fw-semibold">@shop.ShopName</td>
                                <td>@shop.City</td>
                                <td>
                                    @if (shop.Status.ToLower() == "verified")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill">Verified</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill text-dark">Pending</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/shops/details/@shop.Id" class="btn btn-sm btn-outline-primary shadow-sm">View Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private ShopDto[]? shops; 
    private string searchTerm = "";
    private string? statusMessage;

    private IEnumerable<ShopDto> FilteredShops => string.IsNullOrWhiteSpace(searchTerm)
        ? shops ?? Array.Empty<ShopDto>()
        : shops!.Where(s => s.ShopName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                            s.City.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var fetchedShops = await AdminApi.GetShopsAsync();
            // This sorts verified shops to the top, and pending shops to the bottom
            shops = (fetchedShops ?? Array.Empty<ShopDto>())
                .OrderByDescending(s => s.Status.ToLower() == "verified")
                .ToArray();

            statusMessage = AdminApi.LastError;
        }
        catch (Exception ex)
        {
            shops = Array.Empty<ShopDto>();
            statusMessage = $"Failed to load shops: {ex.Message}";
        }
    }
}
