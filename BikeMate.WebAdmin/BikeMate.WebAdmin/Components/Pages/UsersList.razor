@page "/users"
@rendermode InteractiveServer 
@using BikeMate.WebAdmin.DTOs
@using BikeMate.WebAdmin.Services
@inject AdminApiClient AdminApi
@inject IJSRuntime JS

<PageTitle>Admin - Users Directory</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold text-dark">User Directory</h2>

    <div class="d-flex gap-3 align-items-center" style="max-width: 400px; width: 100%;">
        <div class="input-group shadow-sm">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control border-start-0" placeholder="Search..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <a href="/dashboard" class="btn btn-outline-secondary shadow-sm text-nowrap">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (allUsers == null)
        {
            <div class="p-5 text-center">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Loading directory...</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Full Name</th>
                            <th>Account Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in FilteredUsers)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@user.UserId</td>
                                <td class="fw-semibold">@user.FirstName @user.LastName</td>
                                <td>
                                    @if (user.AccountStatus.ToLower() == "active")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill text-dark">@user.AccountStatus</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/users/edit/@user.UserId" class="btn btn-sm btn-primary">Edit</a>

                                    @if (user.AccountStatus.ToLower() == "suspended")
                                    {
                                        <button class="btn btn-sm btn-outline-success ms-1" @onclick="() => HandleSuspendToggle(user.UserId, false)">Unsuspend</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => SuspendUser(user.UserId)">
                                            Suspend
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<ActionMessage Message="@statusMessage" AlertType="@statusType" OnMessageCleared="() => statusMessage = null" />

@code {
    private UserDto[]? allUsers;
    private string? statusMessage;
    private string statusType = "danger";
    private string searchTerm = "";

    // Searches both First and Last names!
    private IEnumerable<UserDto> FilteredUsers => string.IsNullOrWhiteSpace(searchTerm)
        ? allUsers ?? Array.Empty<UserDto>()
        : allUsers!.Where(u => u.FirstName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                               u.LastName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            var fetchedUsers = await AdminApi.GetUsersAsync();
            allUsers = fetchedUsers
                ?? Array.Empty<UserDto>();

            allUsers = allUsers
                .Where(u => !u.LastName.Contains("Mechanic") && !u.LastName.Contains("Admin"))
                .OrderByDescending(u => u.AccountStatus.ToLower() == "active")
                .ToArray();

            if (!string.IsNullOrWhiteSpace(AdminApi.LastError))
            {
                statusType = "danger";
                statusMessage = AdminApi.LastError;
            }
        }
        catch (Exception ex)
        {
            allUsers = Array.Empty<UserDto>();
            statusType = "danger";
            statusMessage = $"Failed to load users: {ex.Message}";
        }
    }

    private async Task SuspendUser(int userId)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to suspend this user?");

        if (confirmed)
        {
            try
            {
                await AdminApi.SuspendUserAsync(userId);
                statusType = "success";
                statusMessage = $"User #{userId} has been suspended.";
                await LoadUsers();
            }
            catch (Exception ex)
            {
                statusType = "danger";
                statusMessage = $"Failed to suspend user: {ex.Message}";
            }
        }
    }

    private async Task HandleSuspendToggle(int userId, bool isSuspending)
    {
        try
        {
            statusMessage = null;

            // If isSuspending is true, set to "suspended". If false, set back to "active"
            string newStatus = isSuspending ? "suspended" : "active";

            await AdminApi.UpdateUserStatusAsync(userId, newStatus);

            await LoadUsers(); // Reload to see the button change colors!

            statusType = "success";
            string actionText = isSuspending ? "suspended" : "reactivated";
            statusMessage = $"User #{userId} has been {actionText}.";
        }
        catch (Exception ex)
        {
            statusType = "danger";
            statusMessage = $"Failed to update user status: {ex.Message}";
        }
    }
}
