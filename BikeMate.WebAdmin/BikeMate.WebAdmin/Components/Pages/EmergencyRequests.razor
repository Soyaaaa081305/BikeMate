@page "/emergency"
@rendermode InteractiveServer
@using BikeMate.WebAdmin.DTOs
@using BikeMate.WebAdmin.Services
@inject AdminApiClient AdminApi

<PageTitle>Emergency Requests</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <div>
        <h2 class="fw-bold text-dark mb-1">Emergency Window</h2>
        <p class="text-muted mb-0">Active requests marked or described as urgent, emergency, accident, breakdown, stranded, or no-start cases.</p>
    </div>

    <div class="d-flex gap-2 align-items-center">
        <button class="btn btn-outline-danger shadow-sm" @onclick="LoadEmergencyRequests" disabled="@isLoading">
            <i class="bi bi-arrow-clockwise me-1"></i> Refresh
        </button>
        <a href="/dashboard" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<ActionMessage Message="@statusMessage" AlertType="danger" OnMessageCleared="() => statusMessage = null" />

<div class="card shadow-sm emergency-card">
    <div class="card-header bg-white border-0 pt-4 pb-3 d-flex justify-content-between align-items-center">
        <div>
            <h5 class="fw-bold mb-0 text-danger"><i class="bi bi-exclamation-octagon-fill me-2"></i>Emergency Queue</h5>
            <small class="text-muted">@EmergencyCount active emergency request@(EmergencyCount == 1 ? "" : "s")</small>
        </div>
        <span class="badge bg-danger px-3 py-2">@EmergencyCount Open</span>
    </div>

    <div class="card-body p-0">
        @if (isLoading)
        {
            <div class="p-5 text-center">
                <div class="spinner-border text-danger" role="status"></div>
                <p class="mt-2 text-muted">Loading emergency requests...</p>
            </div>
        }
        else if (emergencyRequests.Length == 0)
        {
            <div class="p-5 text-center">
                <i class="bi bi-shield-check text-success" style="font-size: 2.5rem;"></i>
                <h5 class="fw-bold mt-3">No active emergencies</h5>
                <p class="text-muted mb-0">Emergency-matching service requests will appear here automatically.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">Req ID</th>
                            <th>Customer</th>
                            <th>Emergency Type</th>
                            <th>Status</th>
                            <th>Amount</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in emergencyRequests)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-danger">#@req.Id</td>
                                <td class="fw-semibold">@req.ClientName</td>
                                <td>
                                    <span class="fw-semibold">@req.ServiceName</span>
                                </td>
                                <td>
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-1">
                                        @req.Status.Replace("_", " ").ToUpper()
                                    </span>
                                </td>
                                <td class="text-success fw-bold">₱@req.TotalAmount.ToString("N2")</td>
                                <td class="text-end pe-4">
                                    <a href="/requests/details/@req.Id" class="btn btn-sm btn-danger shadow-sm">
                                        Open Request
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private ServiceRequestDto[] emergencyRequests = Array.Empty<ServiceRequestDto>();
    private bool isLoading = true;
    private string? statusMessage;
    private int EmergencyCount => emergencyRequests.Length;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmergencyRequests();
    }

    private async Task LoadEmergencyRequests()
    {
        isLoading = true;
        statusMessage = null;

        try
        {
            emergencyRequests = await AdminApi.GetEmergencyRequestsAsync() ?? Array.Empty<ServiceRequestDto>();
            statusMessage = AdminApi.LastError;
        }
        catch (Exception ex)
        {
            emergencyRequests = Array.Empty<ServiceRequestDto>();
            statusMessage = $"Failed to load emergency requests: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
