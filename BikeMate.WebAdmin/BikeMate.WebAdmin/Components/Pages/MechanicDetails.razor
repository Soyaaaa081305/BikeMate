@page "/mechanics/details/{Id:int}"
@rendermode InteractiveServer
@using BikeMate.WebAdmin.DTOs
@using BikeMate.WebAdmin.Services
@inject AdminApiClient AdminApi
@inject IJSRuntime JS

<div class="mb-4 mt-3 d-flex justify-content-between align-items-center">
    <h2 class="fw-bold text-dark mb-0">Mechanic Profile</h2>

    <div class="d-flex gap-2 align-items-center">
        @if (profile != null)
        {
            <button class="btn btn-outline-danger shadow-sm" @onclick="SuspendMechanic" disabled="@isProcessing">
                <i class="bi bi-slash-circle me-1"></i> Suspend
            </button>
        }
        <a href="/mechanics" class="btn btn-outline-secondary shadow-sm ms-2">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<ActionMessage Message="@statusMessage" AlertType="@statusType" OnMessageCleared="() => statusMessage = null" />

@if (profile == null)
{
    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-5 text-center">
                <h5 class="fw-bold">Mechanic profile unavailable</h5>
                <p class="text-muted">@statusMessage</p>
                <button class="btn btn-outline-primary" @onclick="LoadMechanic">Retry</button>
            </div>
        </div>
    }
    else
    {
        <div class="p-5 text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Loading complete mechanic profile...</p>
        </div>
    }
}
else
{
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 text-center pt-4 pb-3 h-100">
                <div class="card-body">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                        @(string.IsNullOrWhiteSpace(profile.FullName) ? "?" : profile.FullName.Substring(0, 1))
                    </div>
                    <h4 class="fw-bold mb-1">@profile.FullName</h4>
                    <p class="text-muted mb-2">@profile.CurrentShopName</p>

                    <div class="mb-4">
                        @if (profile.Status.ToLower() == "online")
                        {
                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">? Online Now</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3 py-2">Offline</span>
                        }
                    </div>

                    <ul class="list-group list-group-flush text-start mb-4">
                        <li class="list-group-item px-0"><i class="bi bi-envelope text-muted me-2"></i> @profile.Email</li>
                        <li class="list-group-item px-0"><i class="bi bi-telephone text-muted me-2"></i> @profile.Phone</li>
                        <li class="list-group-item px-0"><i class="bi bi-briefcase text-muted me-2"></i> @profile.YearsExperience Years Exp.</li>
                    </ul>

                    <div class="bg-light p-3 rounded text-start">
                        <h6 class="fw-bold text-muted small text-uppercase">Biography</h6>
                        <p class="small mb-0">@profile.Bio</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="row g-3 mb-4">
                <div class="col-sm-6">
                    <div class="card shadow-sm border-0 bg-primary text-white h-100">
                        <div class="card-body d-flex align-items-center">
                            <i class="bi bi-star-fill fs-1 opacity-50 me-3"></i>
                            <div>
                                <h6 class="mb-0 opacity-75 text-uppercase fw-bold">Average Rating</h6>
                                <h2 class="mb-0 fw-bold">@profile.AverageRating.ToString("0.0") / 5.0</h2>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="card shadow-sm border-0 bg-success text-white h-100">
                        <div class="card-body d-flex align-items-center">
                            <i class="bi bi-wrench-adjustable-circle fs-1 opacity-50 me-3"></i>
                            <div>
                                <h6 class="mb-0 opacity-75 text-uppercase fw-bold">Completed Jobs</h6>
                                <h2 class="mb-0 fw-bold">@profile.TotalJobs</h2>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white pt-3 pb-2 border-bottom-0">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-clock-history text-primary me-2"></i>Recent Service History</h6>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @if (profile.ServiceHistory.Count == 0)
                        {
                            <li class="list-group-item text-muted p-4 text-center">No service history found.</li>
                        }
                        @foreach (var job in profile.ServiceHistory.Take(5))
                        {
                            <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1 fw-semibold">@job.ServiceName <span class="text-muted small fw-normal ms-2">#@job.RequestId</span></h6>
                                    <small class="text-muted">@job.Date.ToString("MMM dd, yyyy")</small>
                                </div>
                                <span class="badge bg-light text-dark border">@job.Status.Replace("_", " ").ToUpper()</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white pt-3 pb-2 border-bottom-0">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-chat-quote text-warning me-2"></i>Customer Reviews</h6>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @if (profile.Reviews.Count == 0)
                        {
                            <li class="list-group-item text-muted p-4 text-center">No reviews yet.</li>
                        }
                        @foreach (var review in profile.Reviews)
                        {
                            <li class="list-group-item px-4 py-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-semibold">@review.CustomerName</span>
                                    <span class="text-warning">
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                    </span>
                                </div>
                                <p class="mb-1 small text-muted">"@review.Comment"</p>
                                <small class="text-muted" style="font-size: 0.75rem;">@review.Date.ToString("MMM dd, yyyy")</small>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private MechanicProfileDto? profile;
    private bool isProcessing = false;
    private string? statusMessage;
    private string statusType = "danger";

    protected override async Task OnInitializedAsync()
    {
        await LoadMechanic();
    }

    private async Task LoadMechanic()
    {
        statusMessage = null;
        try
        {
            profile = await AdminApi.GetMechanicDetailsAsync(Id);
            if (profile == null)
            {
                statusType = "danger";
                statusMessage = AdminApi.LastError ?? "The mechanic could not be found.";
            }
        }
        catch (Exception ex)
        {
            profile = null;
            statusType = "danger";
            statusMessage = ex.Message;
        }
    }

    private async Task SuspendMechanic()
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"WARNING: Are you sure you want to suspend {profile?.FullName}? They will be forced offline.");
        if (!confirmed) return;

        isProcessing = true;
        try
        {
            await AdminApi.SuspendMechanicAsync(Id);
            statusType = "success";
            statusMessage = "Mechanic suspended successfully.";
            await LoadMechanic();
        }
        catch (Exception ex)
        {
            statusType = "danger";
            statusMessage = ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }
}
